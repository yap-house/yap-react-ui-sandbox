{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "types/**/*.d.ts",
    "oxlint.config.ts",
    "playwright.config.ts",
    "scripts/**/*.ts"
  ]
}
